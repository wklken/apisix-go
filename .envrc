# Keep Go's mutable state inside this checkout. This avoids writes to user
# caches and lets `source .envrc` work without trusting a direnv file outside
# the repository.
export APISIX_GO_ROOT="${APISIX_GO_ROOT:-$PWD}"
export GOPATH="$APISIX_GO_ROOT/.cache/go"
export GOBIN="$APISIX_GO_ROOT/.cache/bin"
export GOCACHE="$APISIX_GO_ROOT/.cache/go-build"
export GOMODCACHE="$APISIX_GO_ROOT/.cache/go-mod"
export GOTMPDIR="$APISIX_GO_ROOT/.cache/tmp"
export TMPDIR="$GOTMPDIR"
export TEST_TELEMETRY_DIR="$APISIX_GO_ROOT/.cache/telemetry"
export GOENV=off
export GOTOOLCHAIN="${GOTOOLCHAIN:-auto}"

mkdir -p "$GOPATH" "$GOBIN" "$GOCACHE" "$GOMODCACHE" "$GOTMPDIR" "$TEST_TELEMETRY_DIR"

# Prefer a toolchain already downloaded into the checkout. When it is absent,
# Go's auto-download still uses the checkout-local GOMODCACHE above.
toolchain_version="$(awk '$1 == "toolchain" { print $2; exit }' "$APISIX_GO_ROOT/go.mod" 2>/dev/null)"
if [[ -n "$toolchain_version" ]]; then
  for candidate in "$GOMODCACHE"/golang.org/toolchain@v0.0.1-"$toolchain_version".*; do
    if [[ -x "$candidate/bin/go" ]]; then
      export GOROOT="$candidate"
      export PATH="$candidate/bin:$PATH"
      export GOTOOLCHAIN=local
      break
    fi
  done
fi

export PATH="$GOBIN:$PATH"
